# ─────────────────────────────────────────────────────────────────
# ZoikoSocial — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real secrets.
# ─────────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<project-ref>/settings/api

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service role key — SERVER ONLY. Never expose to client.
# Used only in server actions, API routes, and migrations.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ZoikoSocial

# ── AUTH ──────────────────────────────────────────────────────────
# Secret used to sign session cookies (generate with: openssl rand -base64 32)
AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ── STORAGE ───────────────────────────────────────────────────────
# Supabase storage bucket names (create in Supabase dashboard)
NEXT_PUBLIC_STORAGE_BUCKET_AVATARS=avatars
NEXT_PUBLIC_STORAGE_BUCKET_POSTS=posts
NEXT_PUBLIC_STORAGE_BUCKET_PETS=pets

# ── RATE LIMITING ─────────────────────────────────────────────────
# Requests per window per IP for public endpoints
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── SAFETY ────────────────────────────────────────────────────────
# Maximum file upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Allowed media MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# ── OPTIONAL: THIRD-PARTY SERVICES ────────────────────────────────
# Only add when the service is integrated

# Email (Resend or similar)
# RESEND_API_KEY=re_...

# Push notifications
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Error tracking
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
