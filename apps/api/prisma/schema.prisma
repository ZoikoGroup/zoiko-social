// ─────────────────────────────────────────────────────────────────────────────
// ZoikoSocial — Prisma Schema
// Primary ORM for all server-side database access in NestJS.
// Supabase is used for Auth, Storage, and RLS (defense-in-depth).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ───────────────────────────────────────────────────────────────────

enum UserState {
  active
  suspended
  banned
  deleted

  @@map("user_state")
}

enum UserRole {
  user
  moderator
  admin
  super_admin

  @@map("user_role")
}

enum VerificationTier {
  none
  email
  phone
  identity
  professional

  @@map("verification_tier")
}

enum VerificationState {
  unverified
  pending
  verified
  rejected

  @@map("verification_state")
}

enum PostType {
  text
  image
  video
  reel
  story

  @@map("post_type")
}

enum PostVisibility {
  public
  followers
  community
  private

  @@map("post_visibility")
}

enum AnimalCategory {
  dog
  cat
  bird
  rabbit
  hamster
  guinea_pig
  fish
  reptile
  horse
  farm_animal
  exotic
  other

  @@map("animal_category")
}

enum LostFoundStatus {
  active
  resolved

  @@map("lost_found_status")
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled

  @@map("booking_status")
}

enum ReviewState {
  pending
  approved
  rejected

  @@map("review_state")
}

enum HealthCertState {
  none
  pending
  approved
  expired

  @@map("health_cert_state")
}

// ── Profile & Network Enums ────────────────────────────────────────────────

enum ConversationType_Deprecated {
  dm
  group
  community

  @@map("conversation_type")
}

enum ProfessionalCategory {
  verified_news_publisher
  product_seller
  pet_care_service_provider
  veterinarian

  @@map("professional_category")
}

enum VerificationRequestStatus {
  pending
  under_review
  approved
  rejected
  additional_info_required

  @@map("verification_request_status")
}

enum FollowStatus {
  active
  blocked

  @@map("follow_status")
}

enum FollowRequestStatus {
  pending
  accepted
  rejected

  @@map("follow_request_status")
}

enum MediaType {
  image
  video

  @@map("media_type")
}

enum CommunityPrivacy {
  public
  private
  invite_only

  @@map("community_privacy")
}

enum CommunityRole {
  owner
  admin
  moderator
  member

  @@map("community_role")
}

enum MemberStatus {
  active
  pending
  banned

  @@map("member_status")
}

enum InviteType {
  user
  link

  @@map("invite_type")
}

// ── Stories Enums ───────────────────────────────────────────────────────────

enum StoryType {
  photo
  video
  text
  shared_post
  shared_professional_profile
  shared_marketplace_product
  shared_community_post

  @@map("story_type")
}

enum StoryStatus {
  processing
  ready
  failed

  @@map("story_status")
}

enum StoryPrivacy {
  public
  followers
  close_friends
  professional

  @@map("story_privacy")
}

enum StoryRefType {
  feed_post
  profile
  product
  community_post

  @@map("story_ref_type")
}

enum StoryMediaType {
  image
  video

  @@map("story_media_type")
}

enum StoryReactionKind {
  emoji
  quick_reply
  dm_reply
  share
  report

  @@map("story_reaction_kind")
}

enum StickerType {
  emoji
  text
  gif
  mention
  hashtag
  time
  date
  weather
  poll
  question
  countdown

  @@map("sticker_type")
}

enum MusicMood {
  happy
  calm
  cinematic
  emotional
  travel
  nature
  pets
  funny
  inspirational
  background
  corporate
  ambient

  @@map("music_mood")
}

enum MusicCategory {
  happy
  calm
  cinematic
  emotional
  travel
  nature
  pets
  funny
  inspirational
  background
  corporate
  ambient

  @@map("music_category")
}

// ── PROFILES MODULE ─────────────────────────────────────────────────────────

model Profile {
  id                String           @id @default(uuid())
  username          String           @unique
  displayName       String           @map("display_name")
  bio               String?
  avatarUrl         String?          @map("avatar_url")
  bannerUrl         String?          @map("banner_url")
  websiteUrl        String?          @map("website_url")
  state             UserState        @default(active)
  role              UserRole         @default(user)
  verificationTier  VerificationTier @default(none) @map("verification_tier")
  isPrivate         Boolean          @default(false) @map("is_private")
  followersCount    Int              @default(0) @map("followers_count")
  followingCount    Int              @default(0) @map("following_count")
  postsCount        Int              @default(0) @map("posts_count")
  trustScore        Int              @default(100) @map("trust_score")
  usernameChangedAt DateTime?        @map("username_changed_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // ── Profile Module Relations ──
  professionalProfile   ProfessionalProfile?
  verificationRequests  VerificationRequest[]

  // ── Network Module Relations ──
  followsAsFollower       Follow[] @relation("FollowAsFollower")
  followsAsFollowing      Follow[] @relation("FollowAsFollowing")
  followRequestsSent      FollowRequest[] @relation("FollowRequestSender")
  followRequestsReceived  FollowRequest[] @relation("FollowRequestReceiver")
  blockedUsers            BlockedUser[] @relation("BlockedUser")
  blockedByUsers          BlockedUser[] @relation("BlockedByUser")
  mutedUsers              MutedUser[] @relation("MutedUser")
  mutedByUsers            MutedUser[] @relation("MutedByUser")

  // ── Core Relations ──
  posts           Post[]
  pets            Pet[]
  eventsHosted    Event[]
  eventRsvps      EventRsvp[]
  adoptionPosts     AdoptionPost[]
  adoptionEnquiries AdoptionEnquiry[]
  serviceProviders  ServiceProvider[]
  lostFoundPosts    LostFoundPost[]
  lostFoundSightings LostFoundSighting[]
  newsArticles      NewsArticle[]
  newsLikes         NewsLike[]
  newsSaves         NewsSave[]
  newsComments      NewsComment[]
  products          Product[]
  productSaves      ProductSave[]
  productEnquiries  ProductEnquiry[]
  breedingProfiles  BreedingProfile[]
  breedingRequests  BreedingRequest[]
  notifications   Notification[]
  userRoles       UserRoleAssignment[]
  auditLogs       AuditLog[]

  // ── Feed Module Relations ──
  likes             Like[]
  comments          Comment[]
  commentLikes      CommentLike[]
  savedPosts        SavedPost[]
  mentionsReceived  Mention[] @relation("MentionedUser")
  mentionsMade      Mention[] @relation("MentionActor")

  // ── Post Analytics Relations ──
  authoredPostEvents PostEvent[] @relation("ProfileAuthoredEvents")
  viewedPostEvents   PostEvent[] @relation("ProfileViewedEvents")

  // ── Communities Module Relations ──
  communitiesCreated Community[]         @relation("CommunityCreator")
  communityMemberships CommunityMember[]
  communityInvitesSent CommunityInvite[] @relation("InviteCreator")
  communityInvitesRcvd CommunityInvite[] @relation("InviteInvitee")

  // ── Stories Module Relations ──
  stories          Story[]
  storyViews       StoryView[]
  storyReactions   StoryReaction[]
  storyMentions    StoryMention[] @relation("StoryMentioned")
  storyMentionsMade StoryMention[] @relation("StoryMentionActor")
  storyHighlights  StoryHighlight[]
  storyArchives    StoryArchive[]

  // ── Messaging Module Relations ──
  conversationMembers        ConversationMember[]
  conversationSettings       ConversationSetting[]
  createdConversations       Conversation[] @relation("ConversationCreator")
  sentMessages               Message[]
  messageReactions           MessageReaction[]
  messageReceipts            MessageReceipt[]
  messageRequestsSent        MessageRequest[] @relation("MessageRequestSender")
  messageRequestsReceived    MessageRequest[] @relation("MessageRequestRecipient")
  groupMemberships           GroupMember[]
  groupJoinRequests          GroupJoinRequest[]
  favoriteContacts           FavoriteContact[] @relation("FavoriteContactUser")
  favoritedBy                FavoriteContact[] @relation("FavoriteContactTarget")
  pinnedChats                PinnedChat[]
  userPresence               UserPresence?
  userPrivacy                UserPrivacy?
  professionalMessaging      ProfessionalMessagingSetting?

  @@map("profiles")
}

model Pet {
  id        String    @id @default(uuid())
  ownerId   String    @map("owner_id")
  name      String
  species   String
  breed     String?
  avatarUrl String?   @map("avatar_url")
  bio       String?
  birthdate DateTime? @db.Date
  isPublic  Boolean   @default(true) @map("is_public")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  owner        Profile           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  diaryEntries PetDiaryEntry[]
  healthRecords PetHealthRecord[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("pets")
}

model PetDiaryEntry {
  id        String   @id @default(uuid())
  petId     String   @map("pet_id")
  ownerId   String   @map("owner_id")
  kind      String   @default("note")   // note | milestone | photo | checkup
  title     String?
  body      String?
  photoUrl  String?  @map("photo_url")
  entryDate DateTime @default(now()) @map("entry_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, entryDate(sort: Desc)])
  @@map("pet_diary")
}

model PetHealthRecord {
  id         String    @id @default(uuid())
  petId      String    @map("pet_id")
  ownerId    String    @map("owner_id")
  type       String                          // vaccination | vet_visit | medication | allergy | weight | note
  title      String
  notes      String?
  recordDate DateTime? @map("record_date") @db.Date
  nextDue    DateTime? @map("next_due") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, recordDate(sort: Desc)])
  @@map("pet_health_records")
}

model Event {
  id          String      @id @default(uuid())
  hostId      String      @map("host_id")
  title       String
  description String?
  location    String?
  isOnline    Boolean     @default(false) @map("is_online")
  coverUrl    String?     @map("cover_url")
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime?   @map("ends_at")
  goingCount  Int         @default(0) @map("going_count")
  isDeleted   Boolean     @default(false) @map("is_deleted")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  host  Profile     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  rsvps EventRsvp[]

  @@index([startsAt])
  @@index([hostId, startsAt])
  @@map("events")
}

model EventRsvp {
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  status    String   @default("going")   // going | interested
  createdAt DateTime @default(now()) @map("created_at")

  event Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
  @@map("event_rsvps")
}

model AdoptionPost {
  id             String   @id @default(uuid())
  posterId       String   @map("poster_id")
  name           String
  species        String
  breed          String?
  age            String?
  sex            String   @default("unknown")   // male | female | unknown
  size           String?                         // small | medium | large
  description    String?
  location       String?
  coverUrl       String?  @map("cover_url")
  photos         String[] @default([])
  vaccinated     Boolean  @default(false)
  neutered       Boolean  @default(false)
  goodWith       String[] @default([]) @map("good_with")
  fee            Int?
  status         String   @default("available")  // available | pending | adopted | withdrawn
  enquiriesCount Int      @default(0) @map("enquiries_count")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  poster    Profile           @relation(fields: [posterId], references: [id], onDelete: Cascade)
  enquiries AdoptionEnquiry[]

  @@index([status, createdAt(sort: Desc)])
  @@index([posterId, createdAt(sort: Desc)])
  @@index([species])
  @@map("adoption_posts")
}

model AdoptionEnquiry {
  id          String   @id @default(uuid())
  listingId   String   @map("listing_id")
  applicantId String   @map("applicant_id")
  message     String?
  status      String   @default("pending")   // pending | accepted | rejected | withdrawn
  createdAt   DateTime @default(now()) @map("created_at")

  listing   AdoptionPost @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant Profile      @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([listingId, applicantId])
  @@index([listingId, createdAt(sort: Desc)])
  @@map("adoption_enquiries")
}

model ServiceProvider {
  id          String   @id @default(uuid())
  addedBy     String   @map("added_by")
  category    String                          // vet | pet_care
  name        String
  serviceType String?  @map("service_type")
  description String?
  location    String?
  address     String?
  phone       String?
  website     String?
  coverUrl    String?  @map("cover_url")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  hiddenAt    DateTime? @map("hidden_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  addedByUser Profile @relation(fields: [addedBy], references: [id], onDelete: Cascade)

  @@index([category, createdAt(sort: Desc)])
  @@index([addedBy])
  @@map("service_providers")
}

model LostFoundPost {
  id               String    @id @default(uuid())
  reporterId       String    @map("reporter_id")
  kind             String                              // lost | found
  petName          String?   @map("pet_name")
  species          String
  breed            String?
  description      String?
  lastSeenLocation String?   @map("last_seen_location")
  lastSeenAt       DateTime? @map("last_seen_at") @db.Date
  photoUrl         String?   @map("photo_url")
  contact          String?
  reward           Int?
  status           String    @default("active")        // active | reunited | closed
  sightingsCount   Int       @default(0) @map("sightings_count")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  reporter  Profile             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  sightings LostFoundSighting[]

  @@index([kind, status, createdAt(sort: Desc)])
  @@index([reporterId])
  @@map("lost_found_posts")
}

model LostFoundSighting {
  id         String   @id @default(uuid())
  postId     String   @map("post_id")
  reporterId String   @map("reporter_id")
  message    String?
  location   String?
  createdAt  DateTime @default(now()) @map("created_at")

  post     LostFoundPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter Profile       @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt(sort: Desc)])
  @@map("lost_found_sightings")
}

model UserRoleAssignment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  grantedBy String?  @map("granted_by")
  grantedAt DateTime @default(now()) @map("granted_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_roles")
}

// ── PROFESSIONAL PROFILE ────────────────────────────────────────────────────

model ProfessionalProfile {
  id             String               @id @default(uuid())
  userId         String               @unique @map("user_id")
  category       ProfessionalCategory
  businessName   String?              @map("business_name")
  businessEmail  String?              @map("business_email")
  businessPhone  String?              @map("business_phone")
  businessAddress String?             @map("business_address")
  description    String?
  websiteUrl     String?              @map("website_url")
  logoUrl        String?              @map("logo_url")
  taxId          String?              @map("tax_id")
  licenseNumber  String?              @map("license_number")
  serviceAreas   String[]             @map("service_areas")
  businessHours  Json?                @map("business_hours")
  isVerified     Boolean              @default(false) @map("is_verified")
  verifiedAt     DateTime?            @map("verified_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("professional_profiles")
}

model ProfessionalSetting {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  showEmail Boolean  @default(false) @map("show_email")
  showPhone Boolean  @default(false) @map("show_phone")
  showAddress Boolean @default(false) @map("show_address")
  availableForBooking Boolean @default(true) @map("available_for_booking")
  notificationPreferences Json? @map("notification_preferences")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("professional_settings")
}

model ProfessionalPermission {
  id           String   @id @default(uuid())
  categorySlug String   @map("category_slug")
  permission   String
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([categorySlug, permission])
  @@map("professional_permissions")
}

// ── VERIFICATION ───────────────────────────────────────────────────────────

model VerificationRequest {
  id              String                    @id @default(uuid())
  userId          String                    @map("user_id")
  type            String                    // 'professional', 'identity', 'organization'
  status          VerificationRequestStatus @default(pending)
  categorySlug    String?                   @map("category_slug")
  notes           String?
  reviewedBy      String?                   @map("reviewed_by")
  reviewedAt      DateTime?                 @map("reviewed_at")
  rejectionReason String?                   @map("rejection_reason")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  user      Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents VerificationDocument[]

  @@index([userId])
  @@index([status])
  @@map("verification_requests")
}

model VerificationDocument {
  id           String   @id @default(uuid())
  requestId    String   @map("request_id")
  documentType String   @map("document_type")
  documentUrl  String   @map("document_url")
  fileName     String?  @map("file_name")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  status       String   @default("pending")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  request VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("verification_documents")
}

// ── NETWORK MODULE ─────────────────────────────────────────────────────────

model Follow {
  followerId  String       @map("follower_id")
  followingId String       @map("following_id")
  status      FollowStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at")

  follower  Profile @relation("FollowAsFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following Profile @relation("FollowAsFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model FollowRequest {
  id         String              @id @default(uuid())
  senderId   String              @map("sender_id")
  receiverId String              @map("receiver_id")
  status     FollowRequestStatus @default(pending)
  message    String?
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  sender   Profile @relation("FollowRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver Profile @relation("FollowRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@map("follow_requests")
}

model BlockedUser {
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  blocker Profile @relation("BlockedUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Profile @relation("BlockedByUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@map("blocked_users")
}

model MutedUser {
  muterId  String   @map("muter_id")
  mutedId  String   @map("muted_id")
  createdAt DateTime @default(now()) @map("created_at")

  muter Profile @relation("MutedUser", fields: [muterId], references: [id], onDelete: Cascade)
  muted Profile @relation("MutedByUser", fields: [mutedId], references: [id], onDelete: Cascade)

  @@id([muterId, mutedId])
  @@map("muted_users")
}

// ── SOCIAL FEED (minimal for profile display) ──────────────────────────────

model Post {
  id               String         @id @default(uuid())
  authorId         String         @map("author_id")
  type             PostType       @default(text)
  kind             String         @default("standard")   // post category: standard|rescue_case|vet_tip|lost_found|wildlife
  metadata         Json?                                  // structured, kind-specific fields
  body             String?        // caption — kept as `body` for DB compat
  mediaUrls        String[]       @map("media_urls")
  visibility       PostVisibility @default(public)
  likesCount       Int            @default(0) @map("likes_count")
  commentsCount    Int            @default(0) @map("comments_count")
  sharesCount      Int            @default(0) @map("shares_count")
  savesCount       Int            @default(0) @map("saves_count")
  commentsDisabled Boolean        @default(false) @map("comments_disabled")
  communityId      String?        @map("community_id")
  safetyCleared    Boolean        @default(false) @map("safety_cleared")
  isDeleted        Boolean        @default(false) @map("is_deleted")
  deletedAt        DateTime?      @map("deleted_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  author    Profile       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community?     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  media     PostMedia[]
  likes     Like[]
  comments  Comment[]
  saves     SavedPost[]
  hashtags  PostHashtag[]
  mentions  Mention[]
  pin       CommunityPostPin?
  events    PostEvent[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([communityId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@index([visibility])
  @@map("posts")
}

// ── POST ANALYTICS — EVENT STREAM (Phase 1) ──────────────────────────────────
// Append-only impression/interaction events for posts by PROFESSIONAL accounts.
// Source of truth for reach/views + follower-vs-non-follower split; Redis holds
// fast counters/HLL mirrors when available. See supabase/migrations/027.
model PostEvent {
  id               String   @id @default(uuid())
  postId           String   @map("post_id")
  authorId         String   @map("author_id")
  viewerId         String?  @map("viewer_id")
  type             String   // free-form: impression | view | profile_tap | link_tap | video_watch | …
  surface          String?  // free-form: feed | explore | hashtag | profile | dm_share | detail | …
  viewerIsFollower Boolean  @default(false) @map("viewer_is_follower")
  deviceType       String?  @map("device_type")
  os               String?
  country          String?
  dwellMs          Int?     @map("dwell_ms")
  props            Json?    // extensible metadata bag (jsonb) — any event-specific fields
  createdAt        DateTime @default(now()) @map("created_at")

  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Profile  @relation("ProfileAuthoredEvents", fields: [authorId], references: [id], onDelete: Cascade)
  viewer Profile? @relation("ProfileViewedEvents", fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([postId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([postId, type])
  @@index([postId, viewerId])
  @@index([createdAt])
  @@map("post_events")
}

model PostMedia {
  id           String    @id @default(uuid())
  postId       String    @map("post_id")
  position     Int       @default(0)
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  type         MediaType @default(image)
  width        Int?
  height       Int?
  fileSize     Int?      @map("file_size")
  blurhash     String?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, position])
  @@map("post_media")
}

model Like {
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, createdAt(sort: Desc)])
  @@map("likes")
}

model Comment {
  id           String   @id @default(uuid())
  postId       String   @map("post_id")
  authorId     String   @map("author_id")
  parentId     String?  @map("parent_id")
  body         String   @db.VarChar(1000)
  likesCount   Int      @default(0) @map("likes_count")
  repliesCount Int      @default(0) @map("replies_count")
  isPinned     Boolean  @default(false) @map("is_pinned")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Profile       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("Replies")
  likes   CommentLike[]
  mentions Mention[]

  @@index([postId, isPinned(sort: Desc), createdAt(sort: Desc)])
  @@index([parentId, createdAt])
  @@map("comments")
}

model CommentLike {
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("comment_likes")
}

model SavedPost {
  userId       String   @map("user_id")
  postId       String   @map("post_id")
  collectionId String?  @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("saved_posts")
}

model Hashtag {
  id         String   @id @default(uuid())
  tag        String   @unique
  postsCount Int      @default(0) @map("posts_count")
  createdAt  DateTime @default(now()) @map("created_at")

  posts   PostHashtag[]
  stories StoryHashtag[]

  @@map("hashtags")
}

model PostHashtag {
  postId    String @map("post_id")
  hashtagId String @map("hashtag_id")

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
  @@map("post_hashtags")
}

model Mention {
  id              String   @id @default(uuid())
  mentionedUserId String   @map("mentioned_user_id")
  actorId         String   @map("actor_id")
  postId          String?  @map("post_id")
  commentId       String?  @map("comment_id")
  createdAt       DateTime @default(now()) @map("created_at")

  mentionedUser Profile  @relation("MentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  actor         Profile  @relation("MentionActor", fields: [actorId], references: [id], onDelete: Cascade)
  post          Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment       Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId, createdAt(sort: Desc)])
  @@map("mentions")
}

// ── NOTIFICATIONS ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ── MESSAGING MODULE ────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────

// ── Messaging Enums ──────────────────────────────────────────────────────────

enum MessageRequestStatus {
  pending
  accepted
  rejected
  expired

  @@map("message_request_status")
}

enum MessageType {
  text
  image
  video
  audio
  voice_note
  document
  gif
  sticker
  location
  contact

  @@map("message_type")
}

enum GroupType {
  private
  public
  invite_only

  @@map("group_type")
}

enum GroupRole {
  owner
  admin
  member

  @@map("group_role")
}

enum GroupPermission {
  send_messages
  edit_group_info
  edit_group_image
  manage_description
  add_members
  remove_members
  promote_admins
  demote_admins
  approve_join_requests
  revoke_invite_links
  pin_messages
  delete_messages
  mention_all
  share_media
  share_files
  share_links

  @@map("group_permission")
}

enum GroupSetting {
  only_admins_can_send
  everyone_can_send
  only_admins_edit_group
  everyone_edit_group
  join_approval_required
  invite_links_enabled
  member_invites_enabled
  mentions_enabled
  read_receipts_enabled
  show_group_history

  @@map("group_setting")
}

enum MessageRequestExpiry {
  seven_days
  fourteen_days
  thirty_days
  never

  @@map("message_request_expiry")
}

enum PresenceStatus {
  online
  offline
  away
  do_not_disturb

  @@map("presence_status")
}

enum PrivacySetting {
  everyone
  my_connections
  my_followers
  nobody

  @@map("privacy_setting")
}

// ── CONVERSATIONS ─────────────────────────────────────────────────────────────

model Conversation {
  id             String   @id @default(uuid())
  type           String   // 'dm' | 'group' | 'community'
  name           String?
  avatarUrl      String?  @map("avatar_url")
  createdBy      String?  @map("created_by")
  lastMessageAt  DateTime? @map("last_message_at")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  creator        Profile?         @relation("ConversationCreator", fields: [createdBy], references: [id])
  members        ConversationMember[]
  messages       Message[]
  settings       ConversationSetting[]
  group          Group?
  pinnedByUsers  PinnedChat[]

  @@index([lastMessageAt])
  @@index([type])
  @@map("conversations")
}

model ConversationMember {
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  groupRole      String   @default("member") @map("group_role")
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime? @map("last_read_at")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at")

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user          Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_members")
}

model ConversationSetting {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  isPinned       Boolean  @default(false) @map("is_pinned")
  isMuted        Boolean  @default(false) @map("is_muted")
  isArchived     Boolean  @default(false) @map("is_archived")
  mutedUntil     DateTime? @map("muted_until")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_settings")
}

// ── MESSAGES ──────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  type           String   @default("text")
  body           String?
  mediaUrls      String[] @default([]) @map("media_urls")
  parentId       String?  @map("parent_id")
  forwardedFrom  String?  @map("forwarded_from")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedForEveryone Boolean @default(false) @map("deleted_for_everyone")
  deletedFor     String[] @default([]) @map("deleted_for")
  editedAt       DateTime? @map("edited_at")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         Profile      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  parent         Message?     @relation("MessageReply", fields: [parentId], references: [id])
  replies        Message[]    @relation("MessageReply")
  forwarded      Message?     @relation("MessageForward", fields: [forwardedFrom], references: [id])
  forwards       Message[]    @relation("MessageForward")
  attachments    MessageAttachment[]
  reactions      MessageReaction[]
  receipts       MessageReceipt[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([parentId])
  @@map("messages")
}

model MessageAttachment {
  id           String   @id @default(uuid())
  messageId    String   @map("message_id")
  type         String
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  fileName     String?  @map("file_name")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  width        Int?
  height       Int?
  duration     Int?
  isVoiceNote  Boolean  @default(false) @map("is_voice_note")
  createdAt    DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("message_reactions")
}

model MessageReceipt {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  status    String   // sent, delivered, read
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId, status])
  @@map("message_receipts")
}

// ── MESSAGE REQUESTS ─────────────────────────────────────────────────────────

model MessageRequest {
  id              String               @id @default(uuid())
  senderId        String               @map("sender_id")
  recipientId     String               @map("recipient_id")
  status          MessageRequestStatus @default(pending)
  message         String?
  expiresAt       DateTime?            @map("expires_at")
  isSpam          Boolean              @default(false) @map("is_spam")
  reviewedByAdmin String?              @map("reviewed_by_admin")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  sender    Profile @relation("MessageRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient Profile @relation("MessageRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([senderId, recipientId])
  @@index([recipientId, status])
  @@index([senderId])
  @@index([expiresAt])
  @@map("message_requests")
}

// ── GROUPS ───────────────────────────────────────────────────────────────────

model Group {
  id              String   @id @default(uuid())
  conversationId  String   @unique @map("conversation_id")
  type            GroupType @default(private)
  description     String?
  coverImageUrl   String?  @map("cover_image_url")
  isAnnouncement  Boolean  @default(false) @map("is_announcement")
  slowModeSeconds Int      @default(0) @map("slow_mode_seconds")
  maxMembers      Int      @default(256) @map("max_members")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  members      GroupMember[]
  settings     GroupSettingModel[]
  inviteLinks  GroupInviteLink[]
  joinRequests GroupJoinRequest[]
  permissions  GroupPermissionModel[]

  @@map("groups")
}

model GroupMember {
  id         String   @id @default(uuid())
  groupId    String   @map("group_id")
  userId     String   @map("user_id")
  role       GroupRole @default(member)
  joinedAt   DateTime @default(now()) @map("joined_at")
  invitedBy  String?  @map("invited_by")
  isApproved Boolean  @default(true) @map("is_approved")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model GroupSettingModel {
  id      String       @id @default(uuid())
  groupId String       @map("group_id")
  setting GroupSetting
  enabled Boolean      @default(true)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, setting])
  @@map("group_settings")
}

model GroupPermissionModel {
  id         String         @id @default(uuid())
  groupId    String         @map("group_id")
  role       GroupRole
  permission GroupPermission

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, role, permission])
  @@map("group_permissions")
}

model GroupInviteLink {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  code      String   @unique
  createdBy String   @map("created_by")
  expiresAt DateTime? @map("expires_at")
  maxUses   Int?     @default(0) @map("max_uses")
  useCount  Int      @default(0) @map("use_count")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([groupId])
  @@map("group_invite_links")
}

model GroupJoinRequest {
  id         String   @id @default(uuid())
  groupId    String   @map("group_id")
  userId     String   @map("user_id")
  status     String   @default("pending")
  message    String?
  reviewedBy String?  @map("reviewed_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@map("group_join_requests")
}

// ── CONTACT MANAGEMENT ───────────────────────────────────────────────────────

model FavoriteContact {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  contactId String   @map("contact_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user    Profile @relation("FavoriteContactUser", fields: [userId], references: [id], onDelete: Cascade)
  contact Profile @relation("FavoriteContactTarget", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@index([userId])
  @@map("favorite_contacts")
}

model PinnedChat {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  conversationId String   @map("conversation_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  user         Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@map("pinned_chats")
}

// ── USER PRESENCE ─────────────────────────────────────────────────────────────

model UserPresence {
  id           String         @id @default(uuid())
  userId       String         @unique @map("user_id")
  status       PresenceStatus @default(offline)
  lastSeen     DateTime?      @map("last_seen")
  isTyping     Boolean        @default(false) @map("is_typing")
  typingIn     String?        @map("typing_in")
  isRecording  Boolean        @default(false) @map("is_recording")
  recordingIn  String?        @map("recording_in")
  device       String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_presence")
}

// ── USER PRIVACY SETTINGS ─────────────────────────────────────────────────────

model UserPrivacy {
  id                     String              @id @default(uuid())
  userId                 String              @unique @map("user_id")
  whoCanMessage          PrivacySetting      @default(everyone) @map("who_can_message")
  whoCanSendMessageRequest PrivacySetting     @default(everyone) @map("who_can_send_message_request")
  whoCanSeeProfilePhoto  PrivacySetting      @default(everyone) @map("who_can_see_profile_photo")
  whoCanSeeLastSeen      PrivacySetting      @default(everyone) @map("who_can_see_last_seen")
  whoCanSeeOnlineStatus  PrivacySetting      @default(everyone) @map("who_can_see_online_status")
  whoCanSeeReadReceipts  PrivacySetting      @default(everyone) @map("who_can_see_read_receipts")
  whoCanAddToGroups      PrivacySetting      @default(everyone) @map("who_can_add_to_groups")
  whoCanMention          PrivacySetting      @default(everyone) @map("who_can_mention")
  messageRequestExpiry   MessageRequestExpiry @default(thirty_days) @map("message_request_expiry")
  showReadReceipts       Boolean             @default(true) @map("show_read_receipts")
  showTypingIndicator    Boolean             @default(true) @map("show_typing_indicator")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_privacy")
}

// ── PROFESSIONAL MESSAGING SETTINGS ───────────────────────────────────────────

model ProfessionalMessagingSetting {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  greetingEnabled       Boolean  @default(false) @map("greeting_enabled")
  greetingMessage       String?  @map("greeting_message")
  awayMessageEnabled    Boolean  @default(false) @map("away_message_enabled")
  awayMessage           String?  @map("away_message")
  awayMessageSchedule   Json?    @map("away_message_schedule")
  businessHoursEnabled  Boolean  @default(false) @map("business_hours_enabled")
  businessHours         Json?    @map("business_hours")
  autoReplyEnabled      Boolean  @default(false) @map("auto_reply_enabled")
  autoReplyMessage      String?  @map("auto_reply_message")
  quickReplies          Json?    @default("[]") @map("quick_replies")
  serviceInquiryEnabled Boolean @default(false) @map("service_inquiry_enabled")
  productInquiryEnabled Boolean @default(false) @map("product_inquiry_enabled")
  appointmentEnabled    Boolean  @default(false) @map("appointment_enabled")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("professional_messaging_settings")
}

// ── RATE LIMITING ───────────────────────────────────────────────────────────

model MessageRateLimit {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  count       Int      @default(0)
  windowStart DateTime @map("window_start")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, windowStart])
  @@map("message_rate_limits")
}

// ── AUDIT LOG ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor Profile? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

// ── COMMUNITIES MODULE ───────────────────────────────────────────────────────

model CommunityCategory {
  id       String  @id @default(uuid())
  slug     String  @unique
  label    String
  icon     String?
  position Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  communities Community[]

  @@map("community_categories")
}

model Community {
  id             String           @id @default(uuid())
  slug           String           @unique
  name           String
  description    String?
  avatarUrl      String?          @map("avatar_url")
  coverUrl       String?          @map("cover_url")
  categoryId     String?          @map("category_id")
  tags           String[]
  privacy        CommunityPrivacy @default(public)
  isVerified     Boolean          @default(false) @map("is_verified")
  membersCount   Int              @default(0) @map("members_count")
  postsCount     Int              @default(0) @map("posts_count")
  createdBy      String           @map("created_by")
  rulesUpdatedAt DateTime?        @map("rules_updated_at")
  isDeleted      Boolean          @default(false) @map("is_deleted")
  deletedAt      DateTime?        @map("deleted_at")
  searchDoc      String           @default("") @map("search_doc")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  category CommunityCategory? @relation(fields: [categoryId], references: [id])
  creator  Profile            @relation("CommunityCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members  CommunityMember[]
  settings CommunitySettings?
  rules    CommunityRule[]
  invites  CommunityInvite[]
  pins     CommunityPostPin[]
  reports  CommunityReport[]
  posts    Post[]

  @@index([categoryId])
  @@index([membersCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("communities")
}

model CommunityMember {
  communityId     String        @map("community_id")
  userId          String        @map("user_id")
  role            CommunityRole @default(member)
  status          MemberStatus  @default(active)
  mutedUntil      DateTime?     @map("muted_until")
  acceptedRulesAt DateTime?     @map("accepted_rules_at")
  invitedBy       String?       @map("invited_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
  @@index([userId])
  @@index([communityId, status, role])
  @@map("community_members")
}

model CommunitySettings {
  communityId       String   @id @map("community_id")
  postApproval      Boolean  @default(false) @map("post_approval")
  membersCanInvite  Boolean  @default(false) @map("members_can_invite")
  notificationPrefs Json?    @map("notification_prefs")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("community_settings")
}

model CommunityRule {
  id          String   @id @default(uuid())
  communityId String   @map("community_id")
  position    Int      @default(0)
  title       String
  body        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, position])
  @@map("community_rules")
}

model CommunityInvite {
  id          String     @id @default(uuid())
  communityId String     @map("community_id")
  type        InviteType
  inviteeId   String?    @map("invitee_id")
  code        String?
  expiresAt   DateTime?  @map("expires_at")
  maxUses     Int?       @map("max_uses")
  uses        Int        @default(0)
  revokedAt   DateTime?  @map("revoked_at")
  createdBy   String     @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  invitee   Profile?  @relation("InviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  creator   Profile   @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([inviteeId])
  @@map("community_invites")
}

model CommunityPostPin {
  communityId String   @map("community_id")
  postId      String   @unique @map("post_id")
  type        String   @default("pin")
  pinnedBy    String   @map("pinned_by")
  createdAt   DateTime @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([communityId, postId])
  @@map("community_post_pins")
}

model CommunityReport {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  reporterId  String    @map("reporter_id")
  targetType  String    @map("target_type")
  targetId    String    @map("target_id")
  reason      String
  note        String?
  status      String    @default("open")
  reviewedBy  String?   @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, reporterId, targetType, targetId])
  @@index([communityId, status])
  @@map("community_reports")
}

/// Platform-wide Trust & Safety report queue (posts, comments, messages,
/// stories, users) — distinct from CommunityReport, which stays scoped to
/// in-community moderation reviewed by a community's own moderators.
model Report {
  id         String    @id @default(uuid())
  reporterId String    @map("reporter_id")
  targetType String    @map("target_type")
  targetId   String    @map("target_id")
  reason     String
  note       String?
  status     String    @default("open")
  reviewedBy String?   @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([reporterId, targetType, targetId])
  @@index([status, createdAt])
  @@map("reports")
}

// ── STORIES MODULE ───────────────────────────────────────────────────────────

model Story {
  id             String        @id @default(uuid())
  authorId       String        @map("author_id")
  type           StoryType
  status         StoryStatus   @default(processing)
  privacy        StoryPrivacy  @default(followers)
  segmentIndex   Int           @default(0) @map("segment_index")
  segmentGroupId String?       @map("segment_group_id")
  caption        String?
  background     Json?
  refType        StoryRefType? @map("ref_type")
  refId          String?       @map("ref_id")
  durationMs     Int           @default(5000) @map("duration_ms")
  viewsCount     Int           @default(0) @map("views_count")
  reactionsCount Int           @default(0) @map("reactions_count")
  repliesCount   Int           @default(0) @map("replies_count")
  impressionsCount Int         @default(0) @map("impressions_count")
  allowReplies   Boolean       @default(true) @map("allow_replies")
  allowReactions Boolean       @default(true) @map("allow_reactions")
  isArchived     Boolean       @default(false) @map("is_archived")
  isDeleted      Boolean       @default(false) @map("is_deleted")
  publishedAt    DateTime?     @map("published_at")
  expiresAt      DateTime?     @map("expires_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  author    Profile          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media     StoryMedia[]
  views     StoryView[]
  reactions StoryReaction[]
  mentions  StoryMention[]
  stickers  StorySticker[]
  music     StoryMusic?
  hashtags  StoryHashtag[]
  highlightItems StoryHighlightItem[]

  @@index([authorId, expiresAt(sort: Desc)])
  @@index([expiresAt])
  @@index([segmentGroupId, segmentIndex])
  @@map("stories")
}

model StoryMedia {
  id             String         @id @default(uuid())
  storyId        String         @map("story_id")
  type           StoryMediaType
  hlsUrl         String?        @map("hls_url")
  mp4FallbackUrl String?        @map("mp4_fallback_url")
  imageUrl       String?        @map("image_url")
  renditions     Json?
  thumbnailUrl   String?        @map("thumbnail_url")
  previewUrl     String?        @map("preview_url")
  blurhash       String?
  width          Int?
  height         Int?
  durationMs     Int?           @map("duration_ms")
  fileSize       Int?           @map("file_size")
  createdAt      DateTime       @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("story_media")
}

model StoryView {
  storyId        String   @map("story_id")
  viewerId       String   @map("viewer_id")
  completionPct  Int      @default(0) @map("completion_pct")
  reacted        Boolean  @default(false)
  replied        Boolean  @default(false)
  profileVisited Boolean  @default(false) @map("profile_visited")
  viewedAt       DateTime @default(now()) @map("viewed_at")

  story  Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer Profile @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId])
  @@index([storyId, viewedAt(sort: Desc)])
  @@index([viewerId])
  @@map("story_views")
}

model StoryReaction {
  id             String            @id @default(uuid())
  storyId        String            @map("story_id")
  userId         String            @map("user_id")
  kind           StoryReactionKind
  emoji          String?
  message        String?
  conversationId String?           @map("conversation_id")
  createdAt      DateTime          @default(now()) @map("created_at")

  story Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("story_reactions")
}

model StoryMention {
  id              String   @id @default(uuid())
  storyId         String   @map("story_id")
  mentionedUserId String   @map("mentioned_user_id")
  actorId         String   @map("actor_id")
  createdAt       DateTime @default(now()) @map("created_at")

  story         Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mentionedUser Profile @relation("StoryMentioned", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  actor         Profile @relation("StoryMentionActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([storyId, mentionedUserId])
  @@index([mentionedUserId, createdAt(sort: Desc)])
  @@map("story_mentions")
}

model StorySticker {
  id        String      @id @default(uuid())
  storyId   String      @map("story_id")
  kind      StickerType
  payload   Json
  transform Json
  createdAt DateTime    @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("story_stickers")
}

model MusicTrack {
  id              String        @id @default(uuid())
  title           String
  artist          String
  album           String?
  genre           String
  mood            MusicMood
  category        MusicCategory
  durationMs      Int           @map("duration_ms")
  coverUrl        String        @map("cover_url")
  previewUrl      String        @map("preview_url")
  audioUrl        String        @map("audio_url")
  license         String
  attribution     String?
  provider        String        @default("internal")
  providerTrackId String?       @map("provider_track_id")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")

  stories StoryMusic[]

  @@index([mood])
  @@index([category])
  @@index([genre])
  @@map("music_tracks")
}

model StoryMusic {
  storyId      String   @id @map("story_id")
  trackId      String   @map("track_id")
  startMs      Int      @default(0) @map("start_ms")
  durationMs   Int?     @map("duration_ms")
  volume       Int      @default(100)
  fadeIn       Boolean  @default(false) @map("fade_in")
  fadeOut      Boolean  @default(false) @map("fade_out")
  muteOriginal Boolean  @default(false) @map("mute_original")
  createdAt    DateTime @default(now()) @map("created_at")

  story Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@index([trackId])
  @@map("story_music")
}

model StoryHashtag {
  storyId   String @map("story_id")
  hashtagId String @map("hashtag_id")

  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([storyId, hashtagId])
  @@index([hashtagId])
  @@map("story_hashtags")
}

model StoryHighlight {
  id         String   @id @default(uuid())
  ownerId    String   @map("owner_id")
  title      String
  coverUrl   String?  @map("cover_url")
  position   Int      @default(0)
  itemsCount Int      @default(0) @map("items_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  owner Profile              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items StoryHighlightItem[]

  @@index([ownerId, position])
  @@map("story_highlights")
}

model StoryHighlightItem {
  id              String   @id @default(uuid())
  highlightId     String   @map("highlight_id")
  archivedStoryId String   @map("archived_story_id")
  position        Int      @default(0)
  addedAt         DateTime @default(now()) @map("added_at")

  highlight StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  story     Story          @relation(fields: [archivedStoryId], references: [id], onDelete: Cascade)

  @@unique([highlightId, archivedStoryId])
  @@index([highlightId, position])
  @@map("story_highlight_items")
}

model StoryArchive {
  storyId    String   @id @map("story_id")
  ownerId    String   @map("owner_id")
  snapshot   Json
  archivedAt DateTime @default(now()) @map("archived_at")
  purgeAfter DateTime @map("purge_after")

  owner Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, archivedAt(sort: Desc)])
  @@index([purgeAfter])
  @@map("story_archive")
}

model NewsArticle {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  title       String
  excerpt     String
  body        String
  coverUrl    String?  @map("cover_url")
  category    String   @default("community")   // policy | science | rescue | health | climate | community
  tier        String   @default("community")   // institutional | verified | community
  sourceName  String?  @map("source_name")
  sourceUrl   String?  @map("source_url")
  readMinutes Int      @default(3) @map("read_minutes")
  featured      Boolean  @default(false)
  likesCount    Int      @default(0) @map("likes_count")
  savesCount    Int      @default(0) @map("saves_count")
  commentsCount Int      @default(0) @map("comments_count")
  status        String   @default("published")   // published | draft
  isDeleted     Boolean  @default(false) @map("is_deleted")
  hiddenAt      DateTime? @map("hidden_at")
  publishedAt   DateTime @default(now()) @map("published_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  author   Profile       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    NewsLike[]
  saves    NewsSave[]
  comments NewsComment[]

  @@index([publishedAt(sort: Desc), id(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@index([authorId, publishedAt(sort: Desc)])
  @@map("news_articles")
}

model NewsComment {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  authorId  String   @map("author_id")
  body      String
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")

  article NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  Profile     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([authorId])
  @@map("news_comments")
}

model NewsLike {
  articleId String   @map("article_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([userId])
  @@map("news_likes")
}

model NewsSave {
  articleId String   @map("article_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([userId])
  @@map("news_saves")
}

model Product {
  id             String   @id @default(uuid())
  sellerId       String   @map("seller_id")
  title          String
  description    String?
  priceCents     Int      @default(0) @map("price_cents")
  compareCents   Int?     @map("compare_cents")
  currency       String   @default("USD")
  category       String   @default("accessories")  // food|toys|health|grooming|accessories|beds|tech
  condition      String   @default("new")          // new | used
  coverUrl       String?  @map("cover_url")
  photos         String[] @default([])
  stock          Int      @default(1)
  shipping       String?
  location       String?
  status         String   @default("active")       // active | sold | withdrawn
  savesCount     Int      @default(0) @map("saves_count")
  enquiriesCount Int      @default(0) @map("enquiries_count")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  hiddenAt       DateTime? @map("hidden_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  seller    Profile          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  saves     ProductSave[]
  enquiries ProductEnquiry[]

  @@index([status, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@map("products")
}

model ProductSave {
  productId String   @map("product_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([productId, userId])
  @@index([userId])
  @@map("product_saves")
}

model ProductEnquiry {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  buyerId   String   @map("buyer_id")
  message   String?
  status    String   @default("pending")   // pending | replied | closed
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   Profile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([productId, buyerId])
  @@index([productId, createdAt(sort: Desc)])
  @@map("product_enquiries")
}

/// One-time Shop purchase via Stripe Checkout. Amount is captured at order
/// creation — later price changes on the product never retroactively affect
/// an in-flight or completed order.
model Order {
  id                       String   @id @default(uuid())
  productId                String   @map("product_id")
  buyerId                  String   @map("buyer_id")
  sellerId                 String   @map("seller_id")
  quantity                 Int      @default(1)
  amountCents              Int      @map("amount_cents")
  currency                 String   @default("USD")
  status                   String   @default("pending") // pending | paid | fulfilled | cancelled | refunded
  stripeCheckoutSessionId  String?  @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId    String?  @map("stripe_payment_intent_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@index([status])
  @@map("orders")
}

model BreedingProfile {
  id             String   @id @default(uuid())
  ownerId        String   @map("owner_id")
  petName        String   @map("pet_name")
  species        String   @default("dog")     // dog|cat|bird|rabbit|other
  breed          String
  sex            String   @default("male")    // male | female
  age            String?
  location       String?
  about          String?
  healthTests    String[] @default([]) @map("health_tests")
  certifications String[] @default([])
  coverUrl       String?  @map("cover_url")
  photos         String[] @default([])
  feeCents       Int?     @map("fee_cents")
  currency       String   @default("USD")
  status         String   @default("available")  // available | paused | unavailable
  requestsCount  Int      @default(0) @map("requests_count")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner    Profile           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  requests BreedingRequest[]

  @@index([status, createdAt(sort: Desc)])
  @@index([species, createdAt(sort: Desc)])
  @@index([ownerId, createdAt(sort: Desc)])
  @@map("breeding_profiles")
}

model BreedingRequest {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  requesterId String   @map("requester_id")
  message     String?
  status      String   @default("pending")   // pending | accepted | declined
  createdAt   DateTime @default(now()) @map("created_at")

  profile   BreedingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requester Profile         @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([profileId, requesterId])
  @@index([profileId, createdAt(sort: Desc)])
  @@map("breeding_requests")
}
