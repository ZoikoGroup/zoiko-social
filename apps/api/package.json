{
  "name": "@zoiko/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate || echo prisma-generate-skipped",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --passWithNoTests",
    "clean": "rm -rf dist",
    "db:check": "prisma migrate diff --from-url $DATABASE_URL --to-schema-datamodel prisma/schema.prisma --exit-code",
    "db:drift": "prisma migrate diff --from-url $DATABASE_URL --to-schema-datamodel prisma/schema.prisma",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@fastify/compress": "^9.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/platform-socket.io": "^11.1.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.1.0",
    "@prisma/client": "6.6.0",
    "@supabase/supabase-js": "^2.46.1",
    "@zoiko/types": "workspace:*",
    "@zoiko/validation": "workspace:*",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "livekit-server-sdk": "^2.17.0",
    "nanoid": "^5.1.16",
    "obscenity": "^0.4.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
